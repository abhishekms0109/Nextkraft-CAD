# Copy this file to backend/.env and set the path (use \\ or forward slashes).
# Restart the terminal after editing. This overrides Windows User env if set.
#
# NEXTKRAFT_QCAD=C:/Program Files/QCAD/qcad.exe
#
# Milliseconds to wait inside QCAD before reading job.json / printing PDF (default 10000).
# NEXTKRAFT_QCAD_STARTUP_DELAY_MS=10000
#
# Optional: override template DXF
# TEMPLATE_DXF=C:/path/to/parking_template.dxf
